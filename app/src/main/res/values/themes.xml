<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Gamerhub" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/bg_card</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/bg_card</item>

        <!-- Accent -->
        <item name="colorTertiary">@color/brand_accent</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/bg_light</item>
        <item name="colorSurface">@color/bg_card</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/bg_light</item>

    </style>

    <!-- Splash -->
    <style name="Theme.Gamerhub.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>

</resources>